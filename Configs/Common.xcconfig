// Default build settings — checked in to git.
//
// Override any of these by creating Configs/Local.xcconfig (gitignored).
// See README for setup. Without Local.xcconfig the project signs ad-hoc and
// skips the auto-install-to-/Applications step.

CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = -
DEVELOPMENT_TEAM =
PROVISIONING_PROFILE_SPECIFIER =

#include? "Local.xcconfig"
